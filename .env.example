# Grafana Google SSO Configuration
# HƯỚNG DẪN: 
# 1. Copy file này thành file tên là `.env`
# 2. Thay thế các giá trị bên dưới bằng Client ID và Client Secret thực tế lấy từ Google Cloud Console

GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
